import setuptools

if __name__ == '__main__':
    setuptools.setup(
        name='pystar',
        version='@PROJECT_VERSION@',
        description='STAR (Simple Tensors Arrays and Rasters) for persistent N-dimensional arrays',
        author='USGS Astrogeology',
        author_email='astroweb@usgs.gov',
        url='https://code.usgs.gov/astrogeology/stards',
        packages=['pystar'],
        package_data={'pystar': ['_pystar.so', '_pystar*.so', '*.so']},
        install_requires=[
            'numpy>=1.20.0',
        ],
        zip_safe=False,  # Some OSes cannot dynamically load an so from an egg (zipfile)
        license='MIT',
        classifiers=[
            'Development Status :: 4 - Beta',
            'Intended Audience :: Science/Research',
            'License :: OSI Approved :: MIT License',
            'Programming Language :: Python :: 3',
            'Programming Language :: C++',
        ],
        python_requires='>=3.8',
    )
